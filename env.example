# Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXX

# Gemini 模型 (預設 gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Google Sheet ID (網址中間那段)
GOOGLE_SHEET_ID=your_sheet_id_here

# Google Sheet 工作表名稱
GOOGLE_SHEET_TAB=工作表1

# Service Account JSON (Base64 編碼)
GOOGLE_CREDENTIALS_JSON=base64_encoded_json_here

# 密碼保護 (留空=不啟用)
APP_PASSWORD=

# === Ragic 整合 (寫入 SFinc 訂單總單) ===
# 啟用旗標：true / false (預設 true)
RAGIC_ENABLED=true
# SFinc 帳號 API Key (Ragic > 帳號設定 > API Key)
RAGIC_API_KEY=
# Ragic 表單位址 (預設指向 SFinc 訂單總單)
RAGIC_BASE_URL=https://ap2.ragic.com/SFinc
RAGIC_FORM_PATH=/forms2/4
